<?xml version="1.0" encoding="utf-8"?>
<resources>
<!-- Sostituisci "Theme.CacciaAlTesoro" con il nome reale del tema principale della tua app -->
<style name="Theme.CacciaAlTesoro" parent="Theme.SplashScreen">
    <!-- Colore di sfondo della Splash di sistema (mettilo uguale a quello della tua Compose Splash) -->
    <item name="windowSplashScreenBackground">#FFFFFF</item>
    <!-- Nasconde l'icona obbligatoria di Android -->
    <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    <!-- Indica quale tema caricare DOPO la splash -->
    <item name="postSplashScreenTheme">@style/Theme.CacciaAlTesoro</item>
</style>
</resources>